{
  "name": "nextjs-approute-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "dev:turbo": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "prepare": "husky",
    "analyze": "ANALYZE=true next build",
    "lighthouse": "lhci autorun",
    "lighthouse:local": "mkdir -p reports && lighthouse http://localhost:3000 --output=html --output-path=./reports/lighthouse.html --chrome-flags='--headless --no-sandbox'",
    "perf:audit": "node scripts/performance-audit.mjs",
    "perf:build": "ANALYZE=true next build && node scripts/performance-audit.mjs",
    "load-test": "k6 run scripts/load-test.k6.js",
    "load-test:local": "BASE_URL=http://localhost:3000 k6 run scripts/load-test.k6.js",
    "load-test:quick": "k6 run --vus 10 --duration 30s scripts/load-test.k6.js",
    "sonar": "bunx sonar-scanner",
    "sbom:generate": "bunx @cyclonedx/cdxgen -o bom.json --format json",
    "sbom:upload": "bash scripts/upload-sbom.sh"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.7",
    "@tanstack/react-query-devtools": "^5.100.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-icons": "^5.6.0",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/eslint-plugin-query": "^5.100.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lighthouse": "^13.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "web-vitals": "^5.2.0"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "ip-address": "^10.2.0",
    "vite": "^8.0.0",
    "brace-expansion": "^1.1.13",
    "postcss": "^8.5.10",
    "picomatch": "^4.0.2",
    "uuid": "^14.0.0",
    "flatted": "^3.4.2",
    "basic-ftp": "^6.0.0",
    "tmp": "^0.2.5",
    "yaml": "^2.8.3",
    "path-to-regexp": "^8.0.0",
    "lodash": "^4.17.24",
    "lodash-es": "^4.17.24"
  }
}
